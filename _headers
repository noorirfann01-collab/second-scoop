# Netlify security headers for Second Scoop (applied to every page).
# Fixes: clickjacking, MIME-sniffing, referrer leakage, weak HSTS, no CSP.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; img-src 'self' data: blob: https:; media-src 'self' blob: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://script.google.com https://lightwidget.com https://cdn.lightwidget.com https://behold.so https://*.behold.so; frame-src 'self' https://lightwidget.com https://www.instagram.com https://instagram.com https://behold.so https://*.behold.so; connect-src 'self' https://script.google.com https://script.googleusercontent.com https://api.github.com https://behold.so https://*.behold.so
